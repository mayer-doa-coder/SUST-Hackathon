APP_ENV=
APP_VERSION=1.0.0
PORT=8000
GATEWAY_UPSTREAM_URL=
GATEWAY_UPSTREAM_TIMEOUT_SECONDS=5
AUTH_REQUIRED=false
AUTH_ISSUER=queuestorm-investigator
AUTH_AUDIENCE=queuestorm-api
AUTH_JWT_SECRET=change-this-in-deployment
AUTH_ACCESS_TOKEN_SECONDS=900
AUTH_REFRESH_TOKEN_SECONDS=604800
AUTH_DEMO_USERNAME=support.agent
AUTH_DEMO_PASSWORD=change-me
AUTH_DEMO_ROLES=support_agent,admin
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
EVIDENCE_SHARD_COUNT=16
EVIDENCE_CACHE_TTL_SECONDS=300
INVESTIGATION_ACTIVE_RULESET_VERSION=rules-2026-06-26.v1
INVESTIGATION_RULE_CACHE_TTL_SECONDS=300
NLG_PROMPT_VERSION=nlg-prompt-2026-06-26.v1
NLG_TEMPLATE_VERSION=nlg-template-2026-06-26.v1
SAFETY_POLICY_VERSION=safety-policy-2026-06-26.v1
GATEWAY_REPLICA_COUNT=2
AUTH_REPLICA_COUNT=2
TICKET_REPLICA_COUNT=3
EVIDENCE_REPLICA_COUNT=4
INVESTIGATION_REPLICA_COUNT=3
NLG_REPLICA_COUNT=2
WORKFLOW_REPLICA_COUNT=2
MESSAGING_REPLICA_COUNT=2
DATABASE_PRIMARY_URL=postgresql://primary/queuestorm
DATABASE_READ_REPLICA_URLS=postgresql://replica-a/queuestorm,postgresql://replica-b/queuestorm
DATABASE_POOL_MIN_SIZE=5
DATABASE_POOL_MAX_SIZE=50
TRANSACTION_SHARD_STRATEGY=account_id_hash
CACHE_BACKEND=in-memory
CACHE_STAMPEDE_JITTER_SECONDS=15
LOAD_TEST_VIRTUAL_USERS=200
LOAD_TEST_DURATION_SECONDS=60
LOAD_TEST_TARGET_P95_MS=5000
SERVICE_NAME=queuestorm-investigator
LOG_LEVEL=INFO
OBSERVABILITY_RECENT_TRACE_LIMIT=100
READINESS_REQUIRE_LLM_KEY=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
LLM_TIMEOUT_SECONDS=8
LLM_MAX_COMPLAINT_CHARS=8000

